{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "watch",
      "dependsOn": ["npm: watch"],
      "problemMatcher": ["$esbuild-watch"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    },
    {
      "type": "npm",
      "script": "watch",
      "problemMatcher": ["$esbuild-watch"],
      "isBackground": true
    },
    {
      "label": "compile",
      "type": "npm",
      "script": "compile",
      "problemMatcher": ["$esbuild"],
      "group": "build"
    }
  ]
}

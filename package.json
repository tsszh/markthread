{
  "name": "markthread",
  "displayName": "MarkThread",
  "description": "Review Markdown with humans, then send feedback back to agents.",
  "version": "0.1.34",
  "publisher": "local",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/tsszh/markthread.git"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Other"
  ],
  "activationEvents": [
    "onLanguage:markdown",
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "markdown.previewStyles": [
      "./media/markdown-preview.css"
    ],
    "markdown.previewScripts": [
      "./media/toc.js"
    ],
    "commands": [
      {
        "command": "markthread.openPreview",
        "title": "Open Review Preview to the Side",
        "category": "MarkThread",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "markthread.openPreviewInPlace",
        "title": "Open Review Preview",
        "category": "MarkThread",
        "icon": "$(comment-discussion)"
      },
      {
        "command": "markthread.openCommentInPreview",
        "title": "Open Comment in Review Preview",
        "category": "MarkThread"
      },
      {
        "command": "markthread.openSource",
        "title": "Open Markdown Source",
        "category": "MarkThread",
        "icon": "$(go-to-file)"
      },
      {
        "command": "markthread.copyToClipboard",
        "title": "Copy Review to Clipboard",
        "category": "MarkThread",
        "icon": "$(clippy)"
      },
      {
        "command": "markthread.saveToFile",
        "title": "Save Review Comments to File",
        "category": "MarkThread",
        "icon": "$(save)"
      },
      {
        "command": "markthread.loadFromFile",
        "title": "Load Review Comments from File",
        "category": "MarkThread",
        "icon": "$(refresh)"
      },
      {
        "command": "markthread.clearAll",
        "title": "Clear All Review Comments",
        "category": "MarkThread",
        "icon": "$(clear-all)"
      },
      {
        "command": "markthread.revealComment",
        "title": "Reveal Review Comment",
        "category": "MarkThread"
      },
      {
        "command": "markthread.createComment",
        "title": "Add Review Comment",
        "category": "MarkThread",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "markthread.replyComment",
        "title": "Reply",
        "category": "MarkThread",
        "enablement": "!commentIsEmpty"
      },
      {
        "command": "markthread.deleteComment",
        "title": "Delete Comment",
        "category": "MarkThread",
        "icon": "$(trash)"
      },
      {
        "command": "markthread.deleteThread",
        "title": "Delete Thread",
        "category": "MarkThread",
        "icon": "$(trash)"
      },
      {
        "command": "markthread.editComment",
        "title": "Edit Comment",
        "category": "MarkThread",
        "icon": "$(edit)"
      },
      {
        "command": "markthread.saveComment",
        "title": "Save",
        "category": "MarkThread"
      },
      {
        "command": "markthread.cancelEditComment",
        "title": "Cancel",
        "category": "MarkThread"
      },
      {
        "command": "markthread.cancelEdit",
        "title": "Cancel Comment Edit",
        "category": "MarkThread"
      },
      {
        "command": "markthread.quickReply",
        "title": "Quick Reply",
        "category": "MarkThread"
      },
      {
        "command": "markthread.expandAllThreads",
        "title": "Expand All Review Comments",
        "category": "MarkThread",
        "icon": "$(expand-all)"
      },
      {
        "command": "markthread.collapseAllThreads",
        "title": "Collapse All Review Comments",
        "category": "MarkThread",
        "icon": "$(collapse-all)"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "markthread",
          "title": "MarkThread",
          "icon": "media/review-icon.svg"
        }
      ]
    },
    "views": {
      "markthread": [
        {
          "id": "markthread.commentsView",
          "name": "Review Comments",
          "type": "webview",
          "icon": "media/review-icon.svg",
          "contextualTitle": "MarkThread"
        }
      ]
    },
    "keybindings": [
      {
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "command": "markthread.openPreviewInPlace",
        "when": "editorTextFocus && !notebookEditorFocused && (editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i)"
      },
      {
        "key": "ctrl+shift+v",
        "mac": "cmd+shift+v",
        "command": "markthread.openSource",
        "when": "activeWebviewPanelId == markThreadPreview"
      },
      {
        "key": "ctrl+k v",
        "mac": "cmd+k v",
        "command": "markthread.openPreview",
        "when": "editorTextFocus && !notebookEditorFocused && (editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i)"
      },
      {
        "key": "enter",
        "command": "markthread.submit",
        "when": "commentEditorFocused && !suggestWidgetVisible"
      },
      {
        "key": "ctrl+enter",
        "mac": "cmd+enter",
        "command": "markthread.submit",
        "when": "commentEditorFocused"
      },
      {
        "key": "alt+enter",
        "command": "markthread.submit",
        "when": "commentEditorFocused"
      },
      {
        "key": "shift+enter",
        "command": "type",
        "args": {
          "text": "\n"
        },
        "when": "commentEditorFocused"
      },
      {
        "key": "escape",
        "command": "markthread.cancelEdit",
        "when": "commentEditorFocused && !suggestWidgetVisible"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "markthread.openPreview",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i",
          "group": "navigation@-1"
        }
      ],
      "commandPalette": [
        {
          "command": "markthread.openPreview",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.openPreviewInPlace",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.openCommentInPreview",
          "when": "false"
        },
        {
          "command": "markthread.openSource",
          "when": "false"
        },
        {
          "command": "markthread.copyToClipboard",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.saveToFile",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.loadFromFile",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.clearAll",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.createComment",
          "when": "false"
        },
        {
          "command": "markthread.replyComment",
          "when": "false"
        },
        {
          "command": "markthread.deleteComment",
          "when": "false"
        },
        {
          "command": "markthread.deleteThread",
          "when": "false"
        },
        {
          "command": "markthread.revealComment",
          "when": "false"
        },
        {
          "command": "markthread.editComment",
          "when": "false"
        },
        {
          "command": "markthread.saveComment",
          "when": "false"
        },
        {
          "command": "markthread.cancelEditComment",
          "when": "false"
        },
        {
          "command": "markthread.cancelEdit",
          "when": "false"
        },
        {
          "command": "markthread.quickReply",
          "when": "false"
        },
        {
          "command": "markthread.expandAllThreads",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        },
        {
          "command": "markthread.collapseAllThreads",
          "when": "editorLangId == markdown || resourceExtname =~ /\\.(md|markdown|mdown|mkd|mkdn|mdwn|mdx|mdc|qmd|rmd)$/i"
        }
      ],
      "comments/commentThread/context": [
        {
          "command": "markthread.createComment",
          "group": "inline@1",
          "when": "commentController == markthread && commentThreadIsEmpty"
        },
        {
          "command": "markthread.replyComment",
          "group": "inline@1",
          "when": "commentController == markthread && !commentThreadIsEmpty"
        },
        {
          "command": "markthread.quickReply",
          "group": "inline@2",
          "when": "commentController == markthread"
        }
      ],
      "comments/commentThread/title": [
        {
          "command": "markthread.expandAllThreads",
          "group": "navigation@1",
          "when": "commentController == markthread"
        },
        {
          "command": "markthread.collapseAllThreads",
          "group": "navigation@2",
          "when": "commentController == markthread"
        },
        {
          "command": "markthread.deleteThread",
          "group": "navigation@3",
          "when": "commentController == markthread"
        }
      ],
      "comments/comment/title": [
        {
          "command": "markthread.editComment",
          "group": "inline@1",
          "when": "commentController == markthread && comment == editable"
        },
        {
          "command": "markthread.deleteComment",
          "group": "inline@2",
          "when": "commentController == markthread"
        }
      ],
      "comments/comment/context": [
        {
          "command": "markthread.saveComment",
          "group": "inline@1",
          "when": "commentController == markthread"
        },
        {
          "command": "markthread.cancelEditComment",
          "group": "inline@2",
          "when": "commentController == markthread"
        }
      ]
    },
    "configuration": {
      "title": "MarkThread",
      "properties": {
        "markThread.quickReplies": {
          "type": "array",
          "items": {
            "type": "string"
          },
          "default": [
            "Looks good",
            "Confirmed",
            "No",
            "Please clarify",
            "Please fix",
            "TODO later"
          ],
          "description": "Quick reply texts shown as pills in the Review panel and offered by the Quick Reply button in comment threads."
        },
        "markThread.copy.includeFileName": {
          "type": "boolean",
          "default": false,
          "description": "Include the file name in each copied review comment."
        },
        "markThread.copy.includeLineNumber": {
          "type": "boolean",
          "default": false,
          "description": "Include the line number in each copied review comment."
        },
        "markThread.copy.includeLineText": {
          "type": "boolean",
          "default": true,
          "description": "Include the quoted source line in each copied review comment."
        },
        "markThread.copy.includeComment": {
          "type": "boolean",
          "default": true,
          "description": "Include the comment text in each copied review comment."
        },
        "markThread.copy.headerTemplate": {
          "type": "string",
          "editPresentation": "multilineText",
          "default": "# Review Comments\n\nPlease address the following review comments on the Markdown document below.\nEach item quotes the source line it refers to.\n\n---\n\n",
          "description": "Prefix (header/prompt) prepended to the copied review."
        },
        "markThread.appearance.language": {
          "type": "string",
          "enum": ["auto", "en", "zh"],
          "enumDescriptions": [
            "Follow VS Code's display language",
            "English",
            "简体中文 (Simplified Chinese)"
          ],
          "default": "auto",
          "description": "Interface language for the Review Preview."
        },
        "markThread.appearance.theme": {
          "type": "string",
          "enum": ["system", "light", "dark"],
          "enumDescriptions": [
            "Follow the active VS Code color theme",
            "Always light",
            "Always dark"
          ],
          "default": "system",
          "description": "Light/dark appearance of the Review Preview."
        },
        "markThread.appearance.accent": {
          "type": "string",
          "enum": ["oxblood", "ink", "pine", "terracotta", "petrol"],
          "enumDescriptions": [
            "Oxblood (deep red)",
            "Graphite ink (near-monochrome)",
            "Pine green",
            "Terracotta",
            "Petrol teal"
          ],
          "default": "oxblood",
          "description": "Accent palette for the Review Preview."
        },
        "markThread.appearance.pageWidth": {
          "type": "string",
          "enum": ["narrow", "medium", "wide", "full"],
          "enumDescriptions": [
            "Narrow (~40rem) — easiest reading measure",
            "Medium (~48rem) — default",
            "Wide (~64rem) — more room for tables",
            "Full width — use the whole panel"
          ],
          "default": "medium",
          "description": "Width of the rendered document in the Review Preview. Wider fits big tables; narrower is easier to read."
        }
      }
    }
  },
  "scripts": {
    "compile": "node esbuild.js && tsc -p tsconfig.test.json",
    "watch": "node esbuild.js --watch",
    "lint": "eslint src",
    "test": "npm run compile && vscode-test",
    "build:standalone": "node esbuild.js",
    "preview": "node esbuild.js && node scripts/preview-server.mjs",
    "package": "npm run compile && vsce package --no-dependencies",
    "vscode:prepublish": "npm run compile"
  },
  "devDependencies": {
    "@eslint/js": "^9.22.0",
    "@types/markdown-it": "^14.1.2",
    "@types/mocha": "^10.0.10",
    "@types/node": "^22.13.10",
    "@types/vscode": "^1.75.0",
    "@typescript-eslint/eslint-plugin": "^8.26.1",
    "@typescript-eslint/parser": "^8.26.1",
    "@vscode/test-cli": "^0.0.10",
    "@vscode/test-electron": "^2.4.1",
    "@vscode/vsce": "^3.3.2",
    "esbuild": "^0.25.1",
    "eslint": "^9.22.0",
    "mocha": "^11.1.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.26.1"
  },
  "dependencies": {
    "chart.js": "^4.5.1",
    "echarts": "^6.1.0",
    "highlight.js": "^11.11.1",
    "markdown-it": "^14.1.0",
    "markdown-it-front-matter": "^0.2.4",
    "markdown-it-github-alerts": "^0.3.1",
    "markdown-it-task-lists": "^2.1.1",
    "mermaid": "^11.15.0",
    "yaml": "^2.9.0"
  }
}
